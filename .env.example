DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=voice.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://voice.example.com
DJANGO_SECURE_SSL_REDIRECT=1
# Optional; defaults to ./models/piper
PIPER_MODEL_DIR=E:\web\text-to-speech\models\piper
PIPER_MODEL_BASE_URL=https://github.com/Asif-Rezan/text-to-speech/releases/latest/download
PUBLIC_SITE_URL=https://your-domain.com
